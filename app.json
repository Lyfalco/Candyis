{
  "expo": {
    "name": "Candyis",
    "slug": "candyis",
    "scheme": "candyis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.candyis.app"
    },
    "android": {
      "package": "com.candyis.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "Candyis uses your photo library to let you set a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#29105B",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#29105B"
          }
        }
      ]
    ]
  }
}
